<?xml version="1.0" encoding="utf-8"?>
<!-- Azkar Widget Background - Green Theme -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Main Background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0D2818"
                android:centerColor="#1A4028"
                android:endColor="#0A3015"
                android:angle="135"
                android:type="linear"/>
            <corners android:radius="18dp"/>
            <stroke android:width="1dp" android:color="#2D5A3D"/>
        </shape>
    </item>
    
    <!-- Inner Glow -->
    <item android:bottom="1dp" android:left="1dp" android:right="1dp" android:top="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1590EE90"
                android:endColor="#00000000"
                android:angle="90"/>
            <corners android:radius="17dp"/>
        </shape>
    </item>
</layer-list>
