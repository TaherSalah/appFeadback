<?xml version="1.0" encoding="utf-8"?>
<!-- 
    ملف خلفية شاشة البداية (Launch Screen Background)
    
    الهدف: تحديد شكل الشاشة التي تظهر عند فتح التطبيق قبل تحميل Flutter
    
    التركيبة:
    1. طبقة الخلفية: صورة بيضاء تملأ الشاشة بالكامل
    2. طبقة الأيقونة: لوجو التطبيق بحجم 200dp × 200dp في المنتصف
    
    ملاحظة: هذا الملف يعمل على جميع إصدارات Android
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- الطبقة الأولى: خلفية بيضاء تملأ الشاشة بالكامل -->
    <item>
        <bitmap android:gravity="fill" android:src="@drawable/background"/>
    </item>
    
    <!-- الطبقة الثانية: أيقونة التطبيق في المنتصف -->
    <!-- android:width & android:height: تحديد حجم الأيقونة لمنع التمدد أو القص -->
    <!-- android:gravity="center": توسيط الأيقونة في الشاشة -->
    <item android:width="200dp" android:height="200dp" android:gravity="center">
        <!-- android:gravity="fill": ملء المساحة المحددة (200dp × 200dp) -->
        <bitmap android:gravity="fill" android:src="@drawable/splash"/>
    </item>
</layer-list>
