<?xml version="1.0" encoding="utf-8"?>
<!-- Charity Widget Background - Golden/Warm Theme -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Main Background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#2D1810"
                android:centerColor="#3D2415"
                android:endColor="#1F1208"
                android:angle="135"
                android:type="linear"/>
            <corners android:radius="18dp"/>
            <stroke android:width="1dp" android:color="#5A3D25"/>
        </shape>
    </item>
    
    <!-- Golden Glow -->
    <item android:bottom="1dp" android:left="1dp" android:right="1dp" android:top="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#15FFD700"
                android:endColor="#00000000"
                android:angle="90"/>
            <corners android:radius="17dp"/>
        </shape>
    </item>
</layer-list>
