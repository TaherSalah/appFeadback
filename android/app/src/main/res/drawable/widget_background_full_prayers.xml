<?xml version="1.0" encoding="utf-8"?>
<!-- Full Prayer Times Widget Background -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Outer Glow -->
    <item android:bottom="2dp" android:left="2dp" android:right="2dp" android:top="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0D1B2A"
                android:centerColor="#152535"
                android:endColor="#1B3A55"
                android:angle="120"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
    
    <!-- Main Background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#121B28"
                android:centerColor="#0E1620"
                android:endColor="#0A121D"
                android:angle="145"
                android:type="linear"/>
            <corners android:radius="18dp"/>
            <stroke android:width="1dp" android:color="#253545"/>
        </shape>
    </item>
    
    <!-- Inner Top Highlight -->
    <item android:bottom="1dp" android:left="1dp" android:right="1dp" android:top="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#15FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="90"/>
            <corners android:radius="17dp"/>
        </shape>
    </item>
</layer-list>
