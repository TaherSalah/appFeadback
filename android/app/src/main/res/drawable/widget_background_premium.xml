<?xml version="1.0" encoding="utf-8"?>
<!-- Premium Gradient Background with Glow Effect -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Outer Glow/Shadow Layer -->
    <item android:bottom="2dp" android:left="2dp" android:right="2dp" android:top="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0D1B2A"
                android:centerColor="#1B2838"
                android:endColor="#1E3A5F"
                android:angle="135"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
    
    <!-- Main Background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1A2332"
                android:centerColor="#0F1923"
                android:endColor="#0A1628"
                android:angle="145"
                android:type="linear"/>
            <corners android:radius="18dp"/>
            <stroke android:width="1dp" android:color="#2A3F5F"/>
        </shape>
    </item>
    
    <!-- Inner Highlight -->
    <item android:bottom="1dp" android:left="1dp" android:right="1dp" android:top="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#20FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="90"/>
            <corners android:radius="17dp"/>
        </shape>
    </item>
</layer-list>
