<?xml version="1.0" encoding="utf-8"?>
<!-- Full Prayer Times Widget Layout V2 - With Chronometer & Glassmorphism -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background_full_prayers"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="top|center_horizontal"
        android:orientation="vertical">

        <!-- Header: City & Next Prayer Countdown -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🕌"
                    android:textSize="14sp"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/widget_full_city"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="القاهرة"
                    android:textColor="#B8C5D6"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Countdown Timer -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/glass_item_background"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/widget_next_prayer_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="العصر"
                    android:textColor="#FFD700"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="4dp"/>
                
                <TextView
                     android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="4dp"/>

                <Chronometer
                    android:id="@+id/prayer_chronometer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:countDown="true" />
            </LinearLayout>
        </LinearLayout>

        <!-- Prayer Times Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Row 1: Fajr + Sunrise + Dhuhr -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="4dp">

                <!-- Fajr -->
                <LinearLayout
                    android:id="@+id/fajr_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/glass_item_background"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="الفجر"
                        android:textColor="#B0BEC5"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/widget_fajr_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4:45"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Sunrise -->
                <LinearLayout
                    android:id="@+id/sunrise_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/glass_item_background"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="الشروق"
                        android:textColor="#B0BEC5"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/widget_sunrise_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="6:12"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Dhuhr -->
                <LinearLayout
                    android:id="@+id/dhuhr_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/glass_item_background"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="الظهر"
                        android:textColor="#B0BEC5"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/widget_dhuhr_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12:15"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2: Asr + Maghrib + Isha -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- Asr -->
                <LinearLayout
                    android:id="@+id/asr_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/glass_item_background"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="العصر"
                        android:textColor="#B0BEC5"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/widget_asr_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3:30"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Maghrib -->
                <LinearLayout
                    android:id="@+id/maghrib_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/glass_item_background"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="المغرب"
                        android:textColor="#B0BEC5"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/widget_maghrib_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5:45"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Isha -->
                <LinearLayout
                    android:id="@+id/isha_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/glass_item_background"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="العشاء"
                        android:textColor="#B0BEC5"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/widget_isha_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7:05"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        
        <!-- Opening App Overlay (Invisible but clickable) -->
        <FrameLayout
            android:id="@+id/widget_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </LinearLayout>
</RelativeLayout>
