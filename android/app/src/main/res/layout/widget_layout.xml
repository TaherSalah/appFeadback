<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background_premium"
    android:padding="16dp">

    <!-- Next Prayer Label -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:text="Next prayer"
        android:textColor="#BBDEFB"
        android:textSize="12sp" />

    <!-- Prayer Name -->
    <TextView
        android:id="@+id/widget_prayer_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_title"
        android:layout_alignParentStart="true"
        android:text="Dhuhr"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold" />

    <!-- Prayer Time -->
    <TextView
        android:id="@+id/widget_prayer_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_prayer_name"
        android:layout_alignParentStart="true"
        android:text="12:09 PM"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:textStyle="bold" />

    <!-- Divider Line -->
    <ImageView
        android:id="@+id/widget_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_above="@+id/widget_bottom_row"
        android:layout_marginBottom="6dp"
        android:background="#40FFFFFF" 
        android:contentDescription="divider" />

    <!-- Time Left Label -->
    <TextView
        android:id="@+id/widget_time_left_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/widget_divider"
        android:layout_alignParentStart="true"
        android:layout_marginBottom="2dp"
        android:text="الوقت المتبقي :"
        android:textColor="#BBDEFB"
        android:textSize="11sp" />

    <!-- Time Left Chronometer -->
    <Chronometer
        android:id="@+id/widget_time_left_chronometer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/widget_time_left_label"
        android:layout_alignParentStart="true"
        android:text="--:--"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:countDown="true" />

    <!-- Bottom Row -->
    <LinearLayout
        android:id="@+id/widget_bottom_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal">

        <!-- Hijri Date -->
        <TextView
            android:id="@+id/widget_hijri_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ramadan 1, 1447 AH"
            android:textColor="#E3F2FD"
            android:textSize="11sp" />

        <!-- City -->
        <TextView
            android:id="@+id/widget_city"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cairo"
            android:textColor="#90CAF9"
            android:textSize="15sp" />

    </LinearLayout>

</RelativeLayout>
