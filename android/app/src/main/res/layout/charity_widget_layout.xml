<?xml version="1.0" encoding="utf-8"?>
<!-- Charity Widget Layout - Golden/Warm Theme -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background_charity"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💝"
                android:textSize="14sp"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/widget_charity_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="صدقاتي هذا الشهر"
                android:textColor="#F0D080"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Total Amount -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/widget_charity_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1,250"
                android:textColor="#FFD700"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:shadowColor="#80FFD700"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="8"/>

            <TextView
                android:id="@+id/widget_charity_currency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" ج.م"
                android:textColor="#E8C860"
                android:textSize="14sp"
                android:layout_marginStart="4dp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- Streak Badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:background="@drawable/streak_badge_background"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥"
                android:textSize="12sp"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/widget_charity_streak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15"
                android:textColor="#FF6B35"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" يوم متتالي"
                android:textColor="#FFB088"
                android:textSize="10sp"
                android:fontFamily="sans-serif"/>
        </LinearLayout>

    </LinearLayout>
</RelativeLayout>
